---
interface Row {
  token: string;
  value: string;
  example?: string;
}

interface Props {
  rows: Row[];
}

const { rows } = Astro.props;
---

<table class="scale">
  <thead>
    <tr>
      <th>Token</th>
      <th>Value</th>
      <th>Example</th>
    </tr>
  </thead>
  <tbody>
    {
      rows.map((row) => (
        <tr>
          <td>
            <code>{row.token}</code>
          </td>
          <td>{row.value}</td>
          <td>{row.example}</td>
        </tr>
      ))
    }
  </tbody>
</table>
